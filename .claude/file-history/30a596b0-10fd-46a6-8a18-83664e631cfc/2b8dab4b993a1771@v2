      transition: box-shadow 0.3s ease;
    }
    .experience-card-featured:hover {
      box-shadow: -4px 0 32px rgba(100,255,218,0.22), 0 0 60px rgba(100,255,218,0.08);
    }

    /* AI Safety 뱃지 */
