  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background-color: #0f1117;
      color: #c9d1d9;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
    }

    /* Navbar */
    nav {
      position: sticky;
      top: 0;
      z-index: 50;
      background-color: rgba(15, 17, 23, 0.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(100, 255, 218, 0.1);
    }

    nav a {
      position: relative;
      color: #c9d1d9;
      text-decoration: none;
      font-size: 0.95rem;
      transition: color 0.3s ease;
    }

    nav a:hover {
      color: #64ffda;
    }

    nav a.active::after {
      content: '';
      position: absolute;
      bottom: -8px;
      left: 0;
      right: 0;
      height: 2px;
      background-color: #64ffda;
    }

    /* Typing Animation */
    @keyframes blink {
      50% {
        opacity: 0;
      }
    }

    .roles-container {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .role-line {
      min-height: 1.2em;
      display: flex;
      align-items: center;
      gap: 0.2em;
    }

    .role-text {
      display: inline;
    }

    .cursor {
      display: inline-block;
      animation: blink 0.75s step-end infinite;
      color: #64ffda;
    }

    .cursor.hidden {
      display: none;
    }

    /* Marquee Animation */
    @keyframes marquee {
      0% {
        transform: translateX(0);
      }

      100% {
        transform: translateX(-50%);
      }
    }

    .marquee-content {
      display: flex;
      animation: marquee 20s linear infinite;
      white-space: nowrap;
    }

    .marquee-item {
      padding: 0 2rem;
      font-size: 1rem;
      font-weight: 600;
      color: #64ffda;
      letter-spacing: 2px;
    }

    /* Decorative Box */
    .deco-box {
      border: 2px solid #64ffda;
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 4rem;
      color: #64ffda;
      font-weight: bold;
      text-shadow: 0 0 20px rgba(100, 255, 218, 0.3);
    }

    /* Skills Card */
    .skill-card {
      border: 2px solid rgba(100, 255, 218, 0.2);
      border-radius: 8px;
      padding: 2rem;
      background-color: rgba(100, 255, 218, 0.05);
      transition: all 0.3s ease;
    }

    .skill-card:hover {
      border-color: #64ffda;
      background-color: rgba(100, 255, 218, 0.1);
      transform: translateY(-5px);
      box-shadow: 0 0 20px rgba(100, 255, 218, 0.2);
    }

    /* Skills Category Container */
    .skills-category {
      margin-bottom: 3rem;
    }

    .skills-category-title {
      font-size: 1.25rem;
      font-weight: 600;
      color: #c9d1d9;
      margin-bottom: 1.5rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    /* Highlighted Data Science Category */
    .skills-category.highlighted {
      padding: 2.5rem;
      background-color: rgba(100, 255, 218, 0.08);
      border: 2px solid rgba(100, 255, 218, 0.3);
      border-radius: 8px;
    }

    .skills-category.highlighted .skills-category-title {
      color: #64ffda;
    }

    .skill-icon {
      width: 60px;
      height: 60px;
      margin-bottom: 1rem;
    }

    /* Accent Dot */
    .accent-dot {
      color: #64ffda;
      display: inline;
    }

    /* Section Heading */
    .section-heading {
      font-size: 2.5rem;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 2rem;
    }

    /* Hero Text Gradient */
    .role-gradient {
      background: linear-gradient(135deg, #64ffda, #6ecfff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-size: 2.5rem;
      font-weight: 700;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .section-heading {
        font-size: 1.875rem;
      }

      .role-gradient {
        font-size: 1.875rem;
      }

      .deco-box {
        font-size: 3rem;
      }

      .marquee-item {
        padding: 0 1rem;
        font-size: 0.875rem;
      }
