      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.25rem 0.75rem;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      background-color: rgba(100,255,218,0.1);
      color: #64ffda;
      border: 1px solid rgba(100,255,218,0.35);
