{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "language": "korean",
    "permissions": {
        "allow": [
            "Bash(npm run lint)",
            "Bash(npm run test *)",
            "Bash(npm run build)"
        ],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)"
        ]
    }
}